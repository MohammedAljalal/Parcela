# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/parcela

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Cloudinary (product/banner image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google Auth
GOOGLE_CLIENT_ID=your_google_client_id_here

# SISP / Vinti4Net — issued by SISP after merchant registration at
# https://comerciante.vinti4.cv. Use SISP's sandbox POS_ID/POS_AUT_CODE for
# testing; they also give you the correct sandbox SISP_URL to use (it differs
# from production). Do NOT invent these values — payments will silently fail.
SISP_POS_ID=your_sisp_pos_id
SISP_POS_AUT_CODE=your_sisp_pos_auth_code
SISP_URL=https://mc.vinti4net.cv/payments

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Twilio SMS Provider
TWILIO_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
